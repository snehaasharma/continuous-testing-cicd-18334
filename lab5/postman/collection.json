{
  "info": {
    "_postman_id": "lab5-user-api",
    "name": "Lab 5 — User API (public demo API)",
    "description": "Uses JSONPlaceholder. Override `baseUrl` in the environment for your own service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET /users/1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "pm.test('JSON has id and name', function () {",
              "  var j = pm.response.json();",
              "  pm.expect(j).to.have.property('id');",
              "  pm.expect(j).to.have.property('name');",
              "});",
              "pm.test('Content-Type JSON', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": "{{baseUrl}}/users/1"
      }
    },
    {
      "name": "GET /users/404 (expect 404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 404', function () { pm.response.to.have.status(404); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": "{{baseUrl}}/users/404"
      }
    }
  ]
}
