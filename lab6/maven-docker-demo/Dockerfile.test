# Day 6 — test execution image (Temurin Alpine + dependency layer cache).
# Slides may show JDK 21 — this repo uses 17 to match other labs; bump the tag when you standardise on 21.
FROM eclipse-temurin:17-jdk-alpine

RUN apk add --no-cache bash

WORKDIR /app

COPY mvnw .
COPY .mvn .mvn
COPY pom.xml .
RUN chmod +x mvnw && ./mvnw dependency:go-offline -B --no-transfer-progress

COPY src src

# Default: full unit test phase (includes PostgresSeedDataTest when DB_* env is set by Compose)
CMD ["./mvnw", "test", "-B", "--no-transfer-progress"]
